{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Whisper",
  "version": "0.1.0",
  "identifier": "com.whisper.client",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Whisper",
        "width": 1120,
        "height": 720,
        "minWidth": 320,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
